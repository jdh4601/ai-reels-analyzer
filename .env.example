# Instagram 토큰과 LLM API 키는 대시보드 설정 화면(/settings)에서 추가하는 것을 권장합니다.
# (data/settings.json 에 로컬 저장)
#
# 아래 env 변수는 선택 사항(하위 호환 폰백)입니다. 설정 화면에 키가 없을 때만 사용됩니다.
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxx

# Docker 등에서 QR 코드로 폰 접속 시 사용할 서버 주소
# 컨테이너 낸부 IP가 아닌, 팀원들이 접속할 호스트 머신의 LAN IP를 지정하세요.
# 예: LAN_HOST=http://192.168.0.25:3000
LAN_HOST=
